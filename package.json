{
  "name": "saintus-create",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "fern docs dev",
    "build": "fern docs build",
    "docs:lint": "markdownlint --fix \"fern/**/*.md\"",
    "docs:spellcheck": "python3 scripts/spellcheck.py",
    "docs:index": "ts-node scripts/generate-index.ts",
    "docs:qa": "ts-node scripts/quality.ts",
    "docs:format": "prettier --write \"fern/**/*.md\"",
    "docs:nav": "ts-node scripts/generate-navigation.ts",
    "format:py": "black scripts/*.py"
  },
  "devDependencies": {
    "@types/lunr": "^2.3.7",
    "fern": "0.0.19",
    "lunr": "^2.3.9",
    "markdown-toc": "^1.2.0",
    "markdownlint-cli": "^0.32.0",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "yaml": "^2.9.0"
  }
}
